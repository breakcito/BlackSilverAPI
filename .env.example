APP_NAME="BlackSilverAPI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:9095
SERVER_PORT=9095

# Localización Perú
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_PE
APP_TIMEZONE=America/Lima

# Logs detallados para desarrollo
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de Datos - Localhost en el VPS
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Drivers
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Autenticación API
JWT_SECRET=